{
  "name": "websocket",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsc-watch --onSuccess \"node dist/index.js\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier .",
    "prepare": "husky",
    "prod:start": "npm run build && pm2 start ecosystem.config.cjs --env production",
    "prod:stop": "pm2 stop ecosystem.config.cjs",
    "prod:restart": "pm2 restart ecosystem.config.cjs",
    "prod:logs": "pm2 logs websocket-app",
    "prod:monitor": "pm2 monit",
    "test": "vitest run src/tests",
    "test:watch": "vitest src/tests",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "knip": "^6.6.2",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "pm2": "^6.0.14",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsc-watch": "^7.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@scalar/express-api-reference": "^0.9.9",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "pino": "^10.3.1",
    "zod-to-openapi": "^0.2.1"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "overrides": {
    "zod-to-openapi": {
      "zod": "$zod"
    }
  }
}
