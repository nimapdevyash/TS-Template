# --- Core Dependencies ---
node_modules/
.pnp/
.pnp.js

# --- Build Outputs ---
# Matches your 'outDir' in tsconfig
dist/
build/
*.tsbuildinfo

# --- Environment & Secrets ---
# NEVER commit these to git
.env
.env.local
.env.*.local
*.pem
*.key

# --- Debug & Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log
# Pino/Logger specific logs if you write to files
logs/*.log

# --- Testing & Coverage ---
coverage/
.nyc_output/
# Vitest specific
.vitest/

# --- IDE & Editor Settings ---
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
# Zed specific
.zed/

# --- OS Specific ---
.DS_Store
Thumbs.db

# --- Tools & Cache ---
.eslintcache
.stylelintcache
.prettiercache
.parcel-cache
.cache/
.turbo/
.next/
.knip/

# --- Optional: Documentation ---
# If you generate static docs from Scalar/OpenAPI
docs/gen/
